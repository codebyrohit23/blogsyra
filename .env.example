# ==============================
# Environment Configuration
# ==============================
# NODE_ENV specifies the environment (development, production)
NODE_ENV="development"

# PORT defines the port the app will run on
PORT="3000"

# APP_NAME specifies the name of your application
APP_NAME="auth_service"

# ==============================
# Database Configuration
# ==============================
# DATABASE_URL is the connection URL for your MongoDB database
DATABASE_URL="mongodb://localhost:27017/school-management"

# TEST_DATABASE_URL is the connection URL for the test database
TEST_DATABASE_URL="mongodb://localhost:27017/school-management-test"

# ==============================
# Authentication Settings
# ==============================
# JWT_SECRET is used to sign the JWT (JSON Web Token)
JWT_SECRET="manage_school_auth"

# JWT_EXPIRES_IN sets the expiration time for the JWT (in days, hours, or minutes)
JWT_EXPIRES_IN="7d"

# BCRYPT_SALT_ROUNDS is the number of rounds for bcrypt hashing
BCRYPT_SALT_ROUNDS="12"

# ==============================
# Logging Configuration
# ==============================
# LOG_LEVEL defines the level of logging for the application (debug, info, warn, error)
LOG_LEVEL="debug"

# ==============================
# Rate Limiting Configuration
# ==============================
# RATE_LIMIT_WINDOW_MS defines the duration in milliseconds for the rate limit window
RATE_LIMIT_WINDOW_MS="900000"

# RATE_LIMIT_MAX_REQUESTS is the maximum number of requests allowed in the window
RATE_LIMIT_MAX_REQUESTS="100"

# ==============================
# Security & CORS Configuration
# ==============================
# CORS_ORIGIN defines the allowed origins for cross-origin requests
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# ==============================
# File Upload Settings
# ==============================
# MAX_FILE_SIZE defines the maximum file size allowed for uploads (in bytes)
MAX_FILE_SIZE="5242880"

# UPLOAD_PATH specifies the path where uploaded files will be stored
UPLOAD_PATH="./uploads"

# ==============================
# Database Seeding Configuration
# ==============================
# SEED_DATABASE controls whether the database should be seeded
SEED_DATABASE="true"

# ==============================
# Token Secrets (JWTs)
# ==============================
# ACCESS_TOKEN_SECRET is the secret key used to sign the access token
ACCESS_TOKEN_SECRET="your-access-token-secret"

# REFRESH_TOKEN_SECRET is the secret key used to sign the refresh token
REFRESH_TOKEN_SECRET="your-refresh-token-secret"

# RESET_PASSWORD_TOKEN_SECRET is the secret used to sign the reset password token
RESET_PASSWORD_TOKEN_SECRET="your-reset-password-token-secret"

# EMAIL_VERIFICATION_TOKEN_SECRET is the secret used to sign email verification tokens
EMAIL_VERIFICATION_TOKEN_SECRET="your-email-verification-token-secret"

# ==============================
# Token Expiry Times
# ==============================
# ACCESS_TOKEN_EXPIRES_IN defines how long the access token lasts
ACCESS_TOKEN_EXPIRES_IN="30m"

# REFRESH_TOKEN_EXPIRES_IN defines how long the refresh token lasts
REFRESH_TOKEN_EXPIRES_IN="7d"

# RESET_PASSWORD_TOKEN_EXPIRES_IN defines how long the reset password token lasts
RESET_PASSWORD_TOKEN_EXPIRES_IN="10m"

# EMAIL_VERIFICATION_TOKEN_EXPIRES_IN defines how long the email verification token lasts
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN="10m"

# ==============================
# Redis Configuration
# ==============================
# REDIS_PASSWORD is the password for the Redis instance
REDIS_PASSWORD="your-redis-password"

# ==============================
# SendGrid Configuration
# ==============================
# EMAIL_FROM is the sender's email address used in emails
EMAIL_FROM="webdevrohit@gmail.com"

# SEND_GRID_API_KEY is the SendGrid API key used to send emails
SEND_GRID_API_KEY="your-sendgrid-api-key"

# ==============================
# General Email Configuration
# ==============================
# EMAIL_APP_PASSWORD is the app password for your email service
EMAIL_APP_PASSWORD="your-email-app-password"

# ==============================
# OTP Configuration
# ==============================
# OTP_LENGTH defines the length of the OTP (One-Time Password)
OTP_LENGTH="6"

# ==============================
# Cloudinary Configuration
# ==============================
# CLOUDINARY_CLOUD_NAME is the name of your Cloudinary cloud
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"

# CLOUDINARY_API_KEY is the Cloudinary API key
CLOUDINARY_API_KEY="your-cloudinary-api-key"

# CLOUDINARY_API_SECRET is the Cloudinary API secret
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"