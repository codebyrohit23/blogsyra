{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
      // "@core/*": ["common/core/*"],
      // "@db/*": ["common/db/*"],
      // "@errors/*": ["common/errors/*"],
      // "@utils/*": ["common/utils/*"],
      // "@middelwares/*": ["common/middelwares/*"],
      // // common modules
      // "@token/*": ["modules/common/token/*"],
      // "@otp/*": ["modules/common/otp/*"],
      // "@email/*": ["modules/common/email/*"],
      // "@file/*": ["modules/common/file/*"],
      // "@cloudinary/*": ["modules/common/cloudinary/*"],
      // "@notification/*": ["modules/common/notification/*"],
      // "@queue/*": ["modules/common/queue/*"],
      // // app modules
      // "@auth/*": ["modules/app/auth/*"],
      // "@user/*": ["modules/app/user/*"],
      // // admin modules
      // "@admin/*": ["modules/admin/*"],
      // "@/*": ["*"]
    }
  },
  "include": ["src", "deleted/config", "deleted/express", "deleted/logger", "deleted/response"],
  "exclude": ["node_modules", "dist"]
}
